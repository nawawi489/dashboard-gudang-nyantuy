# =============================================================================
# Dashboard Gudang Nyantuy - Environment Variables
# Salin file ini ke `.env` dan isi nilai sesuai environment (dev/staging/prod).
# Semua variabel WAJIB diawali VITE_ agar dapat diakses oleh client-side code.
# =============================================================================

# --- API Base URL ---
VITE_API_BASE_URL=https://your-n8n-host.example.com

# --- Auth Credentials ---
VITE_AUTH_PURCHASING_USERNAME=purchasing
VITE_AUTH_PURCHASING_PASSWORD=change-me
VITE_AUTH_SPV_USERNAME=spv
VITE_AUTH_SPV_PASSWORD=change-me

# =============================================================================
# Purchasing Webhooks (full URL per endpoint)
# =============================================================================
VITE_WEBHOOK_GET_BARANG=https://your-n8n-host.example.com/webhook/get-database-vendor
VITE_WEBHOOK_INPUT_PO_V3=https://your-n8n-host.example.com/webhook/input-po-gudang
VITE_WEBHOOK_LIST_PO=https://your-n8n-host.example.com/webhook/warehouse-get-list-po
VITE_WEBHOOK_PAYMENT_PROOF=https://your-n8n-host.example.com/webhook/pembayaran-po-gudang
VITE_WEBHOOK_STRUK_PEMBELIAN_KASPIN=https://your-n8n-host.example.com/webhook/konfirm-input-pembelian-kaspin-gudang
VITE_WEBHOOK_FINANCE_VERIF_PO=https://your-n8n-host.example.com/webhook/finance-verif-po-gudang
VITE_WEBHOOK_INPUT_INVENTORY_REQUEST=https://your-n8n-host.example.com/webhook/input-pengajuan-peralatan-gudang
VITE_WEBHOOK_LIST_PENGAJUAN_INVENTARIS=https://your-n8n-host.example.com/webhook/list-pengajuan-inventaris
VITE_WEBHOOK_LIST_PENGAJUAN_PERALATAN=https://your-n8n-host.example.com/webhook/get-list-pengajuan-peralatan
VITE_WEBHOOK_APPROVE_PENGAJUAN_PERALATAN=https://your-n8n-host.example.com/webhook/approve-pengajuan-peralatan
VITE_WEBHOOK_LIST_INVENTARIS=https://your-n8n-host.example.com/webhook/warehouse-get-list-inventaris
VITE_WEBHOOK_PAYMENT_PROOF_INVENTARIS=https://your-n8n-host.example.com/webhook/pembayaran-inventaris-gudang
VITE_WEBHOOK_GET_DATABASE_PERLENGKAPAN=https://your-n8n-host.example.com/webhook/get-database-perlengkapan
VITE_WEBHOOK_INPUT_PENGAJUAN_PERLENGKAPAN=https://your-n8n-host.example.com/webhook/input-pengajuan-perlengkapan

# =============================================================================
# SPV Webhooks (full URL per endpoint)
# =============================================================================
VITE_SPV_WEBHOOK_GET_TASKS=https://your-n8n-host.example.com/webhook/get-task-spv
VITE_SPV_WEBHOOK_SUBMIT_TASK=https://your-n8n-host.example.com/webhook/submit-checklist
VITE_SPV_WEBHOOK_SUBMIT_DEPOSIT=https://your-n8n-host.example.com/webhook/submit-setoran-outlet
VITE_SPV_WEBHOOK_GET_CASH_SUM=https://your-n8n-host.example.com/webhook/setoran-tunai
VITE_SPV_WEBHOOK_GET_PO_LIST=https://your-n8n-host.example.com/webhook/list-permintaan-po
VITE_SPV_WEBHOOK_CONFIRM_PO=https://your-n8n-host.example.com/webhook/konfirmasi-po-tiba
VITE_SPV_WEBHOOK_SCAN_NOTA=https://your-n8n-host.example.com/webhook/nota-scanner
VITE_SPV_WEBHOOK_GET_PERALATAN_LIST=https://your-n8n-host.example.com/webhook/get-list-pengajuan-peralatan-approved
VITE_SPV_WEBHOOK_CONFIRM_PERALATAN=https://your-n8n-host.example.com/webhook/spv-receipt-peralatan
